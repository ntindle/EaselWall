    "Wallpaper changes daily at the selected time." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "El fondo de pantalla cambia diariamente a la hora seleccionada." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Le fond d'écran change chaque jour à l'heure sélectionnée." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Das Hintergrundbild wird täglich zur gewählten Uhrzeit gewechselt." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "選択した時刻に毎日壁紙が変わります。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "壁纸每天在选定的时间更换。" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "O papel de parede muda diariamente no horário selecionado." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "De achtergrond verandert dagelijks op het geselecteerde tijdstip." } }
      }
    },
    "Unique painting per display" : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Pintura única por pantalla" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tableau unique par écran" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Eigenes Gemälde pro Bildschirm" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ディスプレイごとに異なる絵画" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "每个显示器使用不同的画作" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Pintura única por tela" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Uniek schilderij per scherm" } }
      }
    },
    "When enabled, each monitor gets a different painting. When disabled, monitors with the same orientation share a painting." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Si está activado, cada monitor muestra una pintura diferente. Si está desactivado, los monitores con la misma orientación comparten pintura." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Lorsque activé, chaque écran affiche un tableau différent. Lorsque désactivé, les écrans de même orientation partagent le même tableau." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wenn aktiviert, erhält jeder Monitor ein anderes Gemälde. Wenn deaktiviert, teilen sich Monitore gleicher Ausrichtung ein Gemälde." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "有効にすると、各モニターに異なる絵画が表示されます。無効にすると、同じ向きのモニターは同じ絵画を共有します。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "启用后，每个显示器显示不同的画作。禁用后，相同方向的显示器共享同一幅画。" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Quando ativado, cada monitor exibe uma pintura diferente. Quando desativado, monitores com a mesma orientação compartilham a mesma pintura." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Indien ingeschakeld krijgt elk scherm een ander schilderij. Indien uitgeschakeld delen schermen met dezelfde oriëntatie een schilderij." } }
      }
    },
